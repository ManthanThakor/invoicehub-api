# ── ASP.NET Core ──────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=https://localhost:7001

# ── Database (Neon PostgreSQL) ────────────────────────────────────────
ConnectionStrings__DefaultConnection=Host=your-neon-host.aws.neon.tech;Port=5432;Database=neondb;Username=your_user;Password=your_password;SSL Mode=Require;

# ── JWT ───────────────────────────────────────────────────────────────
Jwt__Secret=your-secret-key-min-32-chars-long-here!!
Jwt__Issuer=InvoiceHub
Jwt__Audience=InvoiceHub
Jwt__AccessTokenExpiryMinutes=60
Jwt__RefreshTokenExpiryDays=30

# ── Email (Gmail SMTP) ────────────────────────────────────────────────
Email__Host=smtp.gmail.com
Email__Port=587
Email__UseSsl=false
Email__Username=your-email@gmail.com
Email__Password=your-app-password
Email__FromName=InvoiceHub
Email__FromAddress=your-email@gmail.com

# ── App Settings ──────────────────────────────────────────────────────
App__BaseUrl=https://localhost:7001
App__Name=InvoiceHub

# ── CORS ──────────────────────────────────────────────────────────────
Cors__AllowedOrigins__0=http://localhost:3000
Cors__AllowedOrigins__1=http://localhost:3001

# ── Storage ───────────────────────────────────────────────────────────
Storage__UploadFolder=uploads

# ── AI (Groq) ─────────────────────────────────────────────────────────
# Get a free API key at https://console.groq.com/keys
AI__Provider=groq
AI__ApiKey=gsk_your_groq_api_key_here
AI__Model=llama-3.3-70b-versatile
AI__BaseUrl=https://api.groq.com/openai/v1

# ── Logging ───────────────────────────────────────────────────────────
Serilog__FilePath=logs/invoicehub-.log
